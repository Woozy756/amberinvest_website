---
import plan2Room from "../../assets/plans/plan2room.png";
import plan3Room from "../../assets/plans/plan3room.png";
import FloorPlansSection, { type FloorPlanTab } from "../shared/FloorPlansSection.astro";
import { getMessages, type Locale } from "../../i18n/translations";

interface Props {
	locale?: Locale;
}

const { locale = "lv" } = Astro.props;
const messages = getMessages(locale);
const section = messages.home.apartmentPlans;

const imageMap = {
	plan2room: plan2Room.src,
	plan3room: plan3Room.src
} as const;

const plans: FloorPlanTab[] = section.plans.map((plan) => ({
	id: plan.imageKey,
	tabLabel: plan.tabLabel,
	title: plan.title,
	price: plan.price,
	image: imageMap[plan.imageKey],
	imageAlt: plan.imageAlt,
	ctaText: plan.ctaText,
	ctaLink: plan.ctaLink,
	specs: plan.specs
}));
---

<FloorPlansSection
	eyebrow={section.eyebrow}
	title={section.title}
	lead={section.lead}
	tabsAriaLabel={section.tabsAriaLabel}
	specsAriaLabel={section.specsAriaLabel}
	plans={plans}
/>

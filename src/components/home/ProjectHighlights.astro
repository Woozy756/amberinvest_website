---
import { getMessages, type Locale } from "../../i18n/translations";

interface Props {
	locale?: Locale;
}

const { locale = "lv" } = Astro.props;
const messages = getMessages(locale);
const section = messages.home.projectHighlights;
const galleryId = `project-gallery-${Math.random().toString(36).slice(2, 9)}`;
---

<section class="project-highlights" aria-labelledby={`${galleryId}-title`}>
	<div class="project-highlights__container">
		<header class="project-highlights__header fade-in">
			<p class="project-highlights__eyebrow">{section.eyebrow}</p>
			<h2 id={`${galleryId}-title`} class="project-highlights__title">{section.title}</h2>
		</header>

		<div class="project-highlights__grid">
			<div class="project-highlights__content">
				<ul class="project-highlights__features" role="list">
					{
						section.features.map((feature, index) => (
							<li class="project-highlights__feature-item fade-in" data-reveal-delay={String(90 + index * 80)}>
								<article class="project-highlights__feature-card">
									<div class="project-highlights__feature-icon" aria-hidden="true">
										{feature.icon === "structure" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M4.75 5.75h14.5v12.5H4.75z" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<path d="M9 5.75v12.5M15 5.75v12.5M4.75 10.5h14.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
											</svg>
										)}
										{feature.icon === "energy" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M12 4.25a2.75 2.75 0 0 0-2.75 2.75v6.58a4.5 4.5 0 1 0 5.5 0V7A2.75 2.75 0 0 0 12 4.25Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<path d="M12 9v6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
											</svg>
										)}
										{feature.icon === "finish" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M6.75 18.25h10.5v-8.5l-5.25-4-5.25 4z" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<path d="M10 18.25v-5.5h4v5.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
											</svg>
										)}
										{feature.icon === "parking" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M7 18.25V6.5h5.5a3.75 3.75 0 0 1 0 7.5H7" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<path d="M16.25 16.25h1.5a1.5 1.5 0 0 1 1.5 1.5v.5h-5v-.5a1.5 1.5 0 0 1 1.5-1.5Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
											</svg>
										)}
										{feature.icon === "lift" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M8 4.75h8a2 2 0 0 1 2 2v10.5a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6.75a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<path d="M10 9.5h4M10 13h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
											</svg>
										)}
										{feature.icon === "location" && (
											<svg viewBox="0 0 24 24" focusable="false">
												<path d="M12 20.25s5-5.1 5-9.1a5 5 0 1 0-10 0c0 4 5 9.1 5 9.1Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
												<circle cx="12" cy="11.25" r="1.75" fill="none" stroke="currentColor" stroke-width="1.5"/>
											</svg>
										)}
									</div>
									<div class="project-highlights__feature-copy">
										<h3>{feature.title}</h3>
										<p>{feature.body}</p>
									</div>
								</article>
							</li>
						))
					}
				</ul>
			</div>

			<div class="project-highlights__media" data-project-gallery>
				<figure class="project-highlights__figure fade-in" data-reveal-delay="140">
					<img
						class="project-highlights__main-image"
						src={section.gallery[0].image}
						alt={section.gallery[0].alt}
						width="960"
						height="720"
						loading="lazy"
						data-gallery-main-image
					/>
				</figure>

				<div class="project-highlights__thumbs" role="tablist" aria-label={section.galleryAriaLabel}>
					{
						section.gallery.map((item, index) => (
							<button
								type="button"
								class:list={{
									"project-highlights__thumb": true,
									"is-active": index === 0,
									"fade-in": true
								}}
								role="tab"
								aria-selected={index === 0 ? "true" : "false"}
								aria-label={item.alt}
								data-gallery-thumb
								data-image={item.image}
								data-alt={item.alt}
								data-reveal-delay={String(220 + index * 55)}
							>
								<img src={item.thumb} alt="" width="160" height="120" loading="lazy" />
							</button>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	document.querySelectorAll('[data-project-gallery]').forEach((gallery) => {
		const mainImage = gallery.querySelector('[data-gallery-main-image]');
		const thumbs = gallery.querySelectorAll('[data-gallery-thumb]');

		if (!mainImage || !thumbs.length) return;

		thumbs.forEach((thumb) => {
			thumb.addEventListener('click', () => {
				const image = thumb.getAttribute('data-image');
				const alt = thumb.getAttribute('data-alt');

				if (!image || !alt) return;

				mainImage.animate(
					[
						{ opacity: 0.86, transform: 'scale(1.01)' },
						{ opacity: 1, transform: 'scale(1)' }
					],
					{ duration: 360, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
				);

				mainImage.setAttribute('src', image);
				mainImage.setAttribute('alt', alt);

				thumbs.forEach((button) => {
					button.classList.remove('is-active');
					button.setAttribute('aria-selected', 'false');
				});

				thumb.classList.add('is-active');
				thumb.setAttribute('aria-selected', 'true');
			});
		});
	});
</script>

<style>
	.project-highlights {
		background: var(--surface-light);
		color: var(--bg-primary);
		padding: clamp(5rem, 9vw, 7.5rem) 0;
	}

	.project-highlights__container {
		width: min(100%, 1280px);
		margin: 0 auto;
		padding: 0 clamp(1.5rem, 4vw, 3rem);
	}

	.project-highlights__header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 54rem;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.project-highlights__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: start;
	}

	.project-highlights__content,
	.project-highlights__media {
		min-width: 0;
	}

	.project-highlights__content {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.project-highlights__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-primary);
	}

	.project-highlights__title {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(2rem, 3.8vw, 3.6rem);
		line-height: 1.08;
		letter-spacing: -0.018em;
		max-width: 18ch;
		text-wrap: balance;
	}

	.project-highlights__features {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
		gap: clamp(1rem, 2vw, 1.35rem);
	}

	.project-highlights__feature-item {
		min-width: 0;
	}

	.project-highlights__feature-card {
		height: 100%;
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1.35rem 0 0;
		border-top: 1px solid rgba(35, 38, 43, 0.14);
		transition:
			transform 0.35s var(--ease-premium),
			border-color 0.35s var(--ease-premium);
	}

	.project-highlights__feature-card:hover,
	.project-highlights__feature-card:focus-within {
		transform: translateY(-2px);
		border-color: rgba(199, 150, 67, 0.4);
	}

	.project-highlights__feature-icon {
		flex: 0 0 auto;
		width: 1.25rem;
		height: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-top: 0.08rem;
		color: var(--accent-primary);
	}

	.project-highlights__feature-icon svg {
		width: 100%;
		height: 100%;
	}

	.project-highlights__feature-copy {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		min-width: 0;
	}

	.project-highlights__feature-copy h3,
	.project-highlights__feature-copy p {
		margin: 0;
	}

	.project-highlights__feature-copy h3 {
		font-size: 1rem;
		line-height: 1.35;
	}

	.project-highlights__feature-copy p {
		font-size: 0.98rem;
		line-height: 1.7;
		color: rgba(15, 17, 21, 0.62);
	}

	.project-highlights__media {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		align-self: center;
	}

	.project-highlights__figure {
		position: relative;
		margin: 0;
		width: 100%;
		aspect-ratio: 1.14 / 0.88;
		overflow: hidden;
		background: linear-gradient(135deg, rgba(15, 17, 21, 0.08), rgba(15, 17, 21, 0.14));
		border: 1px solid rgba(35, 38, 43, 0.08);
	}

	.project-highlights__figure::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(15, 17, 21, 0) 0%, rgba(15, 17, 21, 0.08) 100%);
		pointer-events: none;
	}

	.project-highlights__main-image {
		display: block;
		width: 100%;
		height: 100%;
		max-width: 100%;
		object-fit: cover;
		transition: transform 1.2s var(--ease-premium);
	}

	.project-highlights__media:hover .project-highlights__main-image {
		transform: scale(1.03);
	}

	.project-highlights__thumbs {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(4.9rem, 1fr));
		gap: 0.7rem;
		align-items: start;
	}

	.project-highlights__thumb {
		position: relative;
		display: block;
		padding: 0;
		min-width: 0;
		border: 0;
		border-top: 1px solid rgba(35, 38, 43, 0.14);
		background: transparent;
		cursor: pointer;
		overflow: hidden;
		transition:
			transform 0.3s var(--ease-premium),
			border-color 0.3s var(--ease-premium),
			opacity 0.3s var(--ease-premium);
	}

	.project-highlights__thumb::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		top: 0;
		height: 2px;
		background: var(--accent-primary);
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.3s var(--ease-premium);
		pointer-events: none;
	}

	.project-highlights__thumb img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 100%;
		aspect-ratio: 1.08 / 0.8;
		object-fit: cover;
		opacity: 0.72;
		transition: opacity 0.3s var(--ease-premium), transform 0.7s var(--ease-premium);
	}

	.project-highlights__thumb:hover,
	.project-highlights__thumb:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(199, 150, 67, 0.36);
		outline: none;
	}

	.project-highlights__thumb:hover::after,
	.project-highlights__thumb:focus-visible::after,
	.project-highlights__thumb.is-active::after {
		transform: scaleX(1);
	}

	.project-highlights__thumb:hover img,
	.project-highlights__thumb:focus-visible img,
	.project-highlights__thumb.is-active img {
		opacity: 1;
		transform: scale(1.04);
	}

	@media (max-width: 960px) {
		.project-highlights__header {
			max-width: 40rem;
		}

		.project-highlights__grid {
			grid-template-columns: 1fr;
		}

		.project-highlights__media {
			order: 2;
		}
	}

	@media (max-width: 640px) {
		.project-highlights {
			padding: 4.5rem 0;
		}

		.project-highlights__header {
			margin-bottom: 1.75rem;
		}

		.project-highlights__title {
			max-width: 20ch;
		}

		.project-highlights__thumbs {
			display: flex;
			overflow-x: auto;
			scrollbar-width: thin;
			padding-bottom: 0.25rem;
		}

		.project-highlights__thumb {
			flex: 0 0 min(5.6rem, 24vw);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.project-highlights__feature-card,
		.project-highlights__thumb,
		.project-highlights__thumb::after,
		.project-highlights__thumb img,
		.project-highlights__main-image {
			transition: none;
		}

		.project-highlights__feature-card:hover,
		.project-highlights__feature-card:focus-within,
		.project-highlights__thumb:hover,
		.project-highlights__thumb:focus-visible,
		.project-highlights__media:hover .project-highlights__main-image {
			transform: none;
		}
	}
</style>

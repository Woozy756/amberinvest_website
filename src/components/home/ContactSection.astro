---
import ContactForm from "./ContactForm.jsx";
import type { HomepageContactContent } from "../../sanity/homepage";

interface Props {
	content?: HomepageContactContent | null;
}

const { content } = Astro.props;

const fallbackEyebrow = "Sazinies ar mums";
const fallbackTitle = "Piesakiet konsultāciju";
const fallbackLead =
	"Aizpildiet formu, un mēs sazināsimies, lai vienotos par nākamo soli.";
const eyebrow = content?.contactEyebrow?.trim() || fallbackEyebrow;
const title = content?.contactTitle?.trim() || fallbackTitle;
const lead = content?.contactLead?.trim() || fallbackLead;
const benefits = content?.contactBenefits?.map((benefit) => benefit.trim()).filter(Boolean) ?? [];
---

<section class="contact-section" aria-labelledby="contact-section-title">
	<div class="contact-section__container">
		<div class="contact-section__layout">
			<div class="contact-section__content">
				<p class="contact-section__eyebrow fade-in">{eyebrow}</p>
				<h2 id="contact-section-title" class="contact-section__title fade-in" data-reveal-delay="70">
					{title}
				</h2>
				<p class="contact-section__lead fade-in" data-reveal-delay="130">
					{lead}
				</p>

				{benefits.length > 0 && (
					<ul class="contact-section__benefits" role="list">
						{benefits.map((benefit, index) => (
							<li class="contact-section__benefit fade-in" data-reveal-delay={String(190 + index * 60)}>
								<span class="contact-section__check" aria-hidden="true">
									<img src="/check-mark.svg" alt="" loading="lazy" width="14" height="14" />
								</span>
								<span>{benefit}</span>
							</li>
						))}
					</ul>
				)}
			</div>

			<div class="contact-section__form-wrap fade-in" data-reveal-delay="180">
				<div class="contact-section__card contact-form-card">
					<ContactForm client:idle />
				</div>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.contact-section {
		position: relative;
		overflow: clip;
		background:
			radial-gradient(circle at top left, rgba(199, 150, 67, 0.14), transparent 34%),
			linear-gradient(180deg, #0f1115 0%, #131821 100%);
		color: var(--surface-light);
		padding: clamp(5rem, 10vw, 8rem) 0;
	}

	.contact-section::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(199, 150, 67, 0.1) 0%, transparent 18%),
			repeating-linear-gradient(
				90deg,
				rgba(138, 144, 152, 0.04) 0,
				rgba(138, 144, 152, 0.04) 1px,
				transparent 1px,
				transparent 120px
			);
		opacity: 0.35;
		pointer-events: none;
	}

	.contact-section__container {
		position: relative;
		z-index: 1;
		width: min(100%, 1280px);
		margin: 0 auto;
		padding: 0 clamp(1.5rem, 4vw, 3rem);
	}

	.contact-section__layout {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(20rem, 0.9fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
	}

	.contact-section__content {
		max-width: 34rem;
	}

	.contact-section__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-primary);
	}

	.contact-section__title {
		margin: 1rem 0 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(2.15rem, 4.2vw, 4rem);
		line-height: 1.06;
		letter-spacing: -0.02em;
		max-width: 13ch;
		text-wrap: balance;
	}

	.contact-section__lead {
		margin: 1.25rem 0 0;
		max-width: 43ch;
		font-size: clamp(1rem, 1.3vw, 1.1rem);
		line-height: 1.75;
		color: rgba(245, 243, 238, 0.72);
	}

	.contact-section__benefits {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.95rem;
	}

	.contact-section__benefit {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		font-size: 0.96rem;
		line-height: 1.55;
		color: rgba(245, 243, 238, 0.92);
	}

	.contact-section__check {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 0.95rem;
		height: 0.95rem;
	}

	.contact-section__check img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.contact-section__form-wrap {
		min-width: 0;
	}

	@media (max-width: 900px) {
		.contact-section__layout {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.contact-section {
			padding: 4.5rem 0;
		}

		.contact-section__card {
			padding: 1.2rem;
		}
	}
</style>

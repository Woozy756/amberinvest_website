---
import type { SiteSettings } from "../sanity/siteSettings";
import { splitLines, toPhoneHref } from "../lib/formatting";

interface Props {
	siteSettings?: SiteSettings | null;
}

const { siteSettings = null } = Astro.props;

const footerNavigation = siteSettings?.footerNavigation ?? [];
const visibleFooterNavigation = footerNavigation.filter(
	(item) => item.href.trim().toLowerCase() !== "/faq"
);

const socialLinks = siteSettings?.socialLinks ?? [];
const siteTitle = siteSettings?.siteTitle?.trim() ?? "";
const footerTitle = siteSettings?.footerTitle ?? "";
const footerDescription = siteSettings?.footerDescription ?? "";

const phone = siteSettings?.phone?.trim();
const phoneHref = toPhoneHref(phone);
const contactEmail = siteSettings?.contactEmail?.trim();
const addressLines = splitLines(siteSettings?.address);
const businessHours = siteSettings?.businessHours?.trim();
const hasContacts = Boolean(phone || contactEmail || addressLines.length || businessHours);
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" aria-labelledby="site-footer-title">
	<div class="site-footer__container">
		<div class="site-footer__grid">
			<div class="site-footer__brand fade-in">
				<p class="site-footer__eyebrow">{siteTitle}</p>
				<h2 id="site-footer-title" class="site-footer__title">{footerTitle}</h2>
				<p class="site-footer__description">{footerDescription}</p>
			</div>

			{visibleFooterNavigation.length > 0 ? (
				<nav class="site-footer__nav fade-in" aria-label="Kājenes navigācija" data-reveal-delay="80">
					<p class="site-footer__label">Navigācija</p>
					<ul class="site-footer__list" role="list">
						{visibleFooterNavigation.map((item) => (
							<li><a href={item.href}>{item.label}</a></li>
						))}
					</ul>
				</nav>
			) : null}

			{hasContacts ? (
				<div class="site-footer__contacts fade-in" data-reveal-delay="140">
					<p class="site-footer__label">Kontakti</p>
					<ul class="site-footer__list" role="list">
						{phone && phoneHref ? <li><a href={phoneHref}>{phone}</a></li> : null}
						{contactEmail ? <li><a href={`mailto:${contactEmail}`}>{contactEmail}</a></li> : null}
						{addressLines.map((line) => (
							<li>{line}</li>
						))}
						{businessHours ? <li>{businessHours}</li> : null}
					</ul>
				</div>
			) : null}

			{socialLinks.length > 0 ? (
				<div class="site-footer__socials fade-in" data-reveal-delay="200">
					<p class="site-footer__label">Seko mums</p>
					<div class="site-footer__social-list">
						{socialLinks.map((socialLink) => (
							<a
								class="site-footer__social-link"
								href={socialLink.url}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`Atvērt ${socialLink.platform}`}
							>
								<span class="site-footer__social-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" focusable="false">
										<path
											d="M14.7 5.3H18.7V9.3M18.3 5.7L12 12M11.1 6H7.4A1.4 1.4 0 0 0 6 7.4V16.6A1.4 1.4 0 0 0 7.4 18H16.6A1.4 1.4 0 0 0 18 16.6V12.9"
											fill="none"
											stroke="currentColor"
											stroke-width="1.6"
											stroke-linecap="square"
											stroke-linejoin="miter"
										/>
									</svg>
								</span>
								<span>{socialLink.platform}</span>
							</a>
						))}
					</div>
				</div>
			) : null}
		</div>

		<div class="site-footer__bottom">
			<p class="site-footer__copyright">© {currentYear} {siteTitle}. Visas tiesības aizsargātas.</p>
			<p class="site-footer__credit">
				Mājaslapu izstrādāja
				<a href="https://200iq.eu" target="_blank" rel="noopener">200iq.eu</a>
			</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		background:
			linear-gradient(180deg, rgba(19, 24, 33, 0.96) 0%, #0f1115 100%);
		color: var(--surface-light);
		border-top: 1px solid rgba(138, 144, 152, 0.14);
	}

	.site-footer::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(
				90deg,
				rgba(138, 144, 152, 0.04) 0,
				rgba(138, 144, 152, 0.04) 1px,
				transparent 1px,
				transparent 120px
			);
		opacity: 0.3;
		pointer-events: none;
	}

	.site-footer__container {
		position: relative;
		z-index: 1;
		width: min(100%, 1280px);
		margin: 0 auto;
		padding: clamp(4.5rem, 8vw, 6.5rem) clamp(1.5rem, 4vw, 3rem) 1.5rem;
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) repeat(3, minmax(0, 0.75fr));
		gap: clamp(2rem, 4vw, 3.25rem);
		padding-bottom: clamp(2.25rem, 4vw, 3rem);
		border-bottom: 1px solid rgba(138, 144, 152, 0.14);
	}

	.site-footer__eyebrow,
	.site-footer__label {
		margin: 0 0 1rem;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-primary);
	}

	.site-footer__title {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(1.9rem, 3vw, 2.8rem);
		line-height: 1.08;
		letter-spacing: -0.02em;
		max-width: 12ch;
		text-wrap: balance;
	}

	.site-footer__description {
		margin: 1.1rem 0 0;
		max-width: 34ch;
		font-size: 0.98rem;
		line-height: 1.75;
		color: var(--text-secondary);
	}

	.site-footer__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.8rem;
	}

	.site-footer__list li,
	.site-footer__list a {
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(245, 243, 238, 0.88);
		text-decoration: none;
		transition:
			color 200ms var(--ease-premium),
			transform 200ms var(--ease-premium);
	}

	.site-footer__list a:hover,
	.site-footer__list a:focus-visible,
	.site-footer__credit a:hover,
	.site-footer__credit a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.site-footer__social-list {
		display: grid;
		gap: 0.85rem;
	}

	.site-footer__social-link {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		width: fit-content;
		color: rgba(245, 243, 238, 0.88);
		text-decoration: none;
		transition:
			color 200ms var(--ease-premium),
			transform 200ms var(--ease-premium);
	}

	.site-footer__social-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1rem;
		height: 1rem;
		color: var(--accent-primary);
	}

	.site-footer__social-icon svg {
		width: 100%;
		height: 100%;
	}

	.site-footer__social-link:hover,
	.site-footer__social-link:focus-visible {
		color: var(--accent-primary);
		transform: translateY(-1px);
		outline: none;
	}

	.site-footer__bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.2rem;
		opacity: 1;
		transform: none;
		filter: none;
	}

	.site-footer__copyright,
	.site-footer__credit {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.6;
		color: rgba(245, 243, 238, 0.72);
	}

	.site-footer__credit {
		text-align: right;
	}

	.site-footer__credit a {
		margin-left: 0.35rem;
		color: var(--accent-primary);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: 0.04em;
		transition:
			color 200ms var(--ease-premium),
			opacity 200ms var(--ease-premium);
	}

	@media (max-width: 960px) {
		.site-footer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.site-footer__container {
			padding-top: 4rem;
			padding-bottom: 1.3rem;
		}

		.site-footer__grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.site-footer__bottom {
			flex-direction: column;
			align-items: flex-start;
		}

		.site-footer__credit {
			text-align: left;
		}
	}
</style>

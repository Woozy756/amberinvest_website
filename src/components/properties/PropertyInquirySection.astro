---
import ContactForm from "../home/ContactForm.jsx";
import type { Property } from "../../data/properties";

interface Props {
	property: Property;
}

const { property } = Astro.props as Props;
---

<section class="property-inquiry" id="property-inquiry" aria-labelledby="property-inquiry-title">
	<div class="property-inquiry__container">
		<div class="property-inquiry__layout">
			<div class="property-inquiry__content">
				<p class="property-inquiry__eyebrow fade-in">Apskates pieteikums</p>
				<h2 id="property-inquiry-title" class="property-inquiry__title fade-in" data-reveal-delay="60">
					Rezervējiet apskates laiku vai saņemiet individuālu piedāvājumu
				</h2>
				<p class="property-inquiry__lead fade-in" data-reveal-delay="120">
					Pastāstiet, kas jūs interesē par <strong>{property.title}</strong>, un mēs sagatavosim
					atbilstošu apskates laiku, plānojuma skaidrojumu vai cenas piedāvājumu.
				</p>

				<ul class="property-inquiry__benefits" role="list">
					<li class="property-inquiry__benefit fade-in" data-reveal-delay="180">
						<img src="/check-mark.svg" alt="" loading="lazy" width="14" height="14" />
						<span>Atbildi sagatavojam vienas darba dienas laikā</span>
					</li>
					<li class="property-inquiry__benefit fade-in" data-reveal-delay="230">
						<img src="/check-mark.svg" alt="" loading="lazy" width="14" height="14" />
						<span>Apskati pielāgojam jūsu grafikam</span>
					</li>
					<li class="property-inquiry__benefit fade-in" data-reveal-delay="280">
						<img src="/check-mark.svg" alt="" loading="lazy" width="14" height="14" />
						<span>Saņemsiet arī pieejamības un līdzīgo plānojumu pārskatu</span>
					</li>
				</ul>

				<div class="property-inquiry__contacts fade-in" data-reveal-delay="320">
					<a href="tel:+37120001234">+371 20 001 234</a>
					<a href="mailto:info@amberinvest.lv">info@amberinvest.lv</a>
				</div>
			</div>

			<div class="property-inquiry__form-wrap fade-in" data-reveal-delay="170">
				<div class="property-inquiry__card">
					<ContactForm
						client:idle
						title="Pieteikt apskati"
						intro={`Aizpildiet formu, un mēs sazināsimies par izvēlēto dzīvokli: ${property.title}.`}
						defaultInterest="apskate"
						submitLabel="Pieteikt apskati"
					/>
				</div>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.property-inquiry {
		position: relative;
		overflow: clip;
		background:
			radial-gradient(circle at top left, rgba(199, 150, 67, 0.16), transparent 34%),
			linear-gradient(180deg, #0f1115 0%, #131821 100%);
		color: var(--surface-light);
		padding: clamp(4.8rem, 8vw, 6.5rem) 0;
	}

	.property-inquiry::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, rgba(199, 150, 67, 0.08) 0%, transparent 20%),
			repeating-linear-gradient(
				90deg,
				rgba(138, 144, 152, 0.04) 0,
				rgba(138, 144, 152, 0.04) 1px,
				transparent 1px,
				transparent 120px
			);
		opacity: 0.42;
		pointer-events: none;
	}

	.property-inquiry__container {
		position: relative;
		z-index: 1;
		width: min(100%, 1280px);
		margin: 0 auto;
		padding-inline: clamp(1.5rem, 4vw, 3rem);
	}

	.property-inquiry__layout {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(20rem, 0.92fr);
		gap: clamp(2rem, 5vw, 4.5rem);
		align-items: start;
	}

	.property-inquiry__content {
		max-width: 34rem;
	}

	.property-inquiry__eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-primary);
	}

	.property-inquiry__title {
		margin: 1rem 0 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(2rem, 4vw, 3.5rem);
		line-height: 1.05;
		letter-spacing: -0.025em;
		max-width: 13ch;
		text-wrap: balance;
	}

	.property-inquiry__lead {
		margin: 1.2rem 0 0;
		max-width: 43ch;
		font-size: clamp(1rem, 1.3vw, 1.08rem);
		line-height: 1.72;
		color: rgba(245, 243, 238, 0.74);
	}

	.property-inquiry__lead strong {
		color: var(--surface-light);
		font-weight: 600;
	}

	.property-inquiry__benefits {
		list-style: none;
		margin: 2rem 0 0;
		padding: 0;
		display: grid;
		gap: 0.9rem;
	}

	.property-inquiry__benefit {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(245, 243, 238, 0.92);
	}

	.property-inquiry__benefit img {
		flex: 0 0 auto;
		width: 0.95rem;
		height: 0.95rem;
		object-fit: contain;
	}

	.property-inquiry__contacts {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.4rem;
		margin-top: 2rem;
		padding-top: 1.35rem;
		border-top: 1px solid rgba(245, 243, 238, 0.12);
	}

	.property-inquiry__contacts a {
		color: var(--surface-light);
		text-decoration: none;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.property-inquiry__contacts a:hover,
	.property-inquiry__contacts a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.property-inquiry__card {
		background: var(--surface-light);
		color: var(--bg-primary);
		border: 1px solid rgba(138, 144, 152, 0.18);
		padding: clamp(1.5rem, 3vw, 2.4rem);
		box-shadow: 0 14px 34px rgba(4, 8, 14, 0.08);
	}

	.contact-form {
		display: grid;
		gap: 1.25rem;
	}

	.contact-form__header {
		display: grid;
		gap: 0.55rem;
		margin-bottom: 0.15rem;
	}

	.contact-form__title {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(1.65rem, 2.4vw, 2.15rem);
		line-height: 1.08;
		letter-spacing: -0.02em;
	}

	.contact-form__intro {
		margin: 0;
		font-size: 0.96rem;
		line-height: 1.7;
		color: rgba(15, 17, 21, 0.62);
	}

	.contact-form__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem 1rem;
	}

	.contact-form__field {
		display: grid;
		gap: 0.4rem;
	}

	.contact-form__field--full {
		grid-column: 1 / -1;
	}

	.contact-form__label {
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgba(15, 17, 21, 0.58);
	}

	.contact-form__control,
	.contact-form__select {
		width: 100%;
		min-height: 3.35rem;
		padding: 0.92rem 1rem;
		border: 1px solid rgba(35, 38, 43, 0.18);
		background: rgba(255, 255, 255, 0.72);
		color: var(--bg-primary);
		font: inherit;
		transition:
			border-color 180ms var(--ease-premium),
			background-color 180ms var(--ease-premium);
	}

	.contact-form__control::placeholder {
		color: rgba(15, 17, 21, 0.34);
	}

	.contact-form__control:focus,
	.contact-form__select:focus {
		outline: none;
		border-color: var(--accent-primary);
		background: #fff;
	}

	.contact-form__control[aria-invalid="true"],
	.contact-form__select[aria-invalid="true"] {
		border-color: #b14b4b;
	}

	.contact-form__hint,
	.contact-form__error,
	.contact-form__status {
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.contact-form__hint {
		color: rgba(15, 17, 21, 0.5);
	}

	.contact-form__error,
	.contact-form__status--error {
		color: #9c2f2f;
	}

	.contact-form__status--success {
		color: #3f6d4b;
	}

	.contact-form__checkbox {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding-top: 0.15rem;
	}

	.contact-form__checkbox input {
		width: 1rem;
		height: 1rem;
		margin-top: 0.1rem;
		accent-color: var(--accent-primary);
	}

	.contact-form__checkbox label {
		font-size: 0.92rem;
		line-height: 1.6;
		color: rgba(15, 17, 21, 0.78);
	}

	.contact-form__submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 3rem;
		padding: 0.65rem 1rem;
		border: 0;
		background: var(--accent-primary);
		color: var(--bg-primary);
		font: inherit;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		cursor: pointer;
		transition:
			background-color 180ms var(--ease-premium),
			transform 180ms var(--ease-premium);
	}

	.contact-form__submit:hover,
	.contact-form__submit:focus-visible {
		background: var(--accent-hover);
		transform: translateY(-2px);
		outline: none;
	}

	.contact-form__submit:disabled {
		cursor: wait;
		opacity: 0.8;
	}

	@media (max-width: 840px) {
		.property-inquiry__layout {
			grid-template-columns: 1fr;
		}

		.contact-form__grid {
			grid-template-columns: 1fr;
		}
	}
</style>

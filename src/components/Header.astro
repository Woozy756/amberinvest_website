---
import { getMessages, type Locale } from "../i18n/translations";
import { getPropertyCategories, getPropertyCategoryHref } from "../sanity/properties";
import type { SiteLink, SiteSettings } from "../sanity/siteSettings";

interface Props {
	overlay?: boolean;
	locale?: Locale;
	siteSettings?: SiteSettings | null;
}

const { overlay = false, locale = "lv", siteSettings = null } = Astro.props;
const messages = getMessages(locale);
const propertyCategories = await getPropertyCategories();

const isPropertiesLink = (item: SiteLink) => {
	const href = item.href.trim().toLowerCase();
	return href === "/properties" || href.startsWith("/properties?");
};

const isFaqLink = (item: SiteLink) => item.href.trim().toLowerCase() === "/faq";

const configuredNavItems = siteSettings?.headerNavigation ?? [];

const visibleNavItems = configuredNavItems.filter((item) => !isFaqLink(item));
const firstPropertiesItem = visibleNavItems.find(isPropertiesLink);
const propertiesLabel = firstPropertiesItem?.label || messages.header.properties;
const mainNavItems = visibleNavItems.filter((item) => !isPropertiesLink(item));
const leadingNavItems = mainNavItems.slice(0, 1);
const trailingNavItems = mainNavItems.slice(1);

const homeAriaLabel = siteSettings?.siteTitle ?? "Sākumlapa";
const logo = siteSettings?.logo;
const logoAlt = logo?.alt || siteSettings?.siteTitle || "";
const headerCtaLabel = "Sazinies ar mums";

const propertiesItems = [
	{ href: "/properties", label: messages.header.propertiesListing },
	...propertyCategories.map((category) => ({
		href: getPropertyCategoryHref(category),
		label: category.label
	}))
];
---

<header class="site-header" data-header data-overlay={overlay} data-scrolled="false" data-menu-open="false" data-properties-open="false">
	<div class="site-header__shell">
		<div class="site-header__inner">
			<a class:list={["brand", { "brand--with-image": Boolean(logo?.url) }]} href="/" aria-label={homeAriaLabel}>
				<span class:list={["brand__mark", { "brand__mark--image": Boolean(logo?.url) }]} aria-hidden={logo?.url ? "false" : "true"}>
					{logo?.url ? (
						<img class="brand__mark-image" src={logo.url} alt={logoAlt} loading="eager" decoding="async" />
					) : (
						"AI"
					)}
				</span>
			</a>

			<nav class="nav nav--desktop" aria-label={messages.header.navAriaLabel}>
				<ul class="nav__list">
					{
						leadingNavItems.map((item) => (
							<li>
								<a class="nav__link" href={item.href}>{item.label}</a>
							</li>
						))
					}
					<li class="nav__item nav__item--has-dropdown">
						<button
							class="nav__link nav__toggle"
							type="button"
							aria-expanded="false"
							aria-controls="properties-menu-desktop"
						>
							{propertiesLabel}
							<span class="nav__caret" aria-hidden="true"></span>
						</button>
						<div class="dropdown" id="properties-menu-desktop">
							<ul class="dropdown__list">
								{
									propertiesItems.map((item) => (
										<li>
											<a class="dropdown__link" href={item.href}>{item.label}</a>
										</li>
									))
								}
							</ul>
						</div>
					</li>
					{
						trailingNavItems.map((item) => (
							<li>
								<a class="nav__link" href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div class="site-header__actions">
				<a class="header-cta" href="/contact">{headerCtaLabel}</a>
				<button
					class="menu-toggle"
					type="button"
					data-menu-button
					aria-expanded="false"
					aria-controls="mobile-menu"
				>
					<span class="sr-only">{messages.header.menuOpenLabel}</span>
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
		</div>

		<div class="mobile-menu" id="mobile-menu" data-mobile-menu>
			<nav aria-label={messages.header.mobileNavAriaLabel}>
				<ul class="mobile-nav">
					{
						leadingNavItems.map((item) => (
							<li>
								<a class="mobile-nav__link" href={item.href}>{item.label}</a>
							</li>
						))
					}
					<li class="mobile-nav__item mobile-nav__item--expandable">
						<button
							class="mobile-nav__toggle"
							type="button"
							data-properties-button
							aria-expanded="false"
							aria-controls="mobile-properties-menu"
						>
							<span>{propertiesLabel}</span>
							<span class="nav__caret" aria-hidden="true"></span>
						</button>
						<ul class="mobile-subnav" id="mobile-properties-menu">
							{
								propertiesItems.map((item) => (
									<li>
										<a class="mobile-subnav__link" href={item.href}>{item.label}</a>
									</li>
								))
							}
						</ul>
					</li>
					{
						trailingNavItems.map((item) => (
							<li>
								<a class="mobile-nav__link" href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
			</nav>
			<a class="header-cta header-cta--mobile" href="/contact">{headerCtaLabel}</a>
		</div>
	</div>
</header>

<script>
	const header = document.querySelector("[data-header]");
	const menuButton = header?.querySelector("[data-menu-button]");
	const propertiesButton = header?.querySelector("[data-properties-button]");
	const desktopMedia = window.matchMedia("(min-width: 960px)");

	const syncScrollState = () => {
		if (!header) return;
		header.dataset.scrolled = window.scrollY > 16 ? "true" : "false";
	};

	const closeMobileMenus = () => {
		if (!header || !menuButton || !propertiesButton) return;
		header.dataset.menuOpen = "false";
		header.dataset.propertiesOpen = "false";
		menuButton.setAttribute("aria-expanded", "false");
		propertiesButton.setAttribute("aria-expanded", "false");
	};

	menuButton?.addEventListener("click", () => {
		if (!header) return;
		const nextState = header.dataset.menuOpen !== "true";
		header.dataset.menuOpen = nextState ? "true" : "false";
		menuButton.setAttribute("aria-expanded", String(nextState));

		if (!nextState && propertiesButton) {
			header.dataset.propertiesOpen = "false";
			propertiesButton.setAttribute("aria-expanded", "false");
		}
	});

	propertiesButton?.addEventListener("click", () => {
		if (!header) return;
		const nextState = header.dataset.propertiesOpen !== "true";
		header.dataset.propertiesOpen = nextState ? "true" : "false";
		propertiesButton.setAttribute("aria-expanded", String(nextState));
	});

	desktopMedia.addEventListener("change", (event) => {
		if (event.matches) closeMobileMenus();
	});

	window.addEventListener("scroll", syncScrollState, { passive: true });
	window.addEventListener("astro:page-load", syncScrollState);

	syncScrollState();
	if (desktopMedia.matches) closeMobileMenus();
</script>

<style>
	.site-header {
		--header-height: 5.25rem;
		position: sticky;
		top: 0;
		z-index: 50;
		margin-bottom: calc(var(--header-height) * -1);
		border-bottom: 1px solid transparent;
		transition:
			background-color 240ms var(--ease-premium),
			border-color 240ms var(--ease-premium),
			backdrop-filter 240ms var(--ease-premium),
			box-shadow 240ms var(--ease-premium);
	}

	.site-header[data-overlay="false"] {
		background-color: var(--nav-surface);
		border-color: rgba(138, 144, 152, 0.14);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.site-header[data-overlay="true"][data-scrolled="true"] {
		background-color: var(--nav-surface);
		border-color: rgba(138, 144, 152, 0.14);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 12px 36px rgba(4, 8, 14, 0.24);
	}

	.site-header__shell {
		width: min(100%, 1280px);
		margin-inline: auto;
		padding-inline: clamp(1.25rem, 4vw, 3rem);
	}

	.site-header__inner {
		min-height: var(--header-height);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.5rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		color: var(--surface-light);
		text-decoration: none;
	}

	.brand__mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		border: 1px solid rgba(199, 150, 67, 0.42);
		background: rgba(199, 150, 67, 0.12);
		color: var(--accent-primary);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.brand__mark--image {
		width: clamp(6.5rem, 12vw, 9rem);
		height: clamp(2.4rem, 4vw, 3rem);
		min-width: 0;
		padding: 0;
		background: transparent;
		border: 0;
	}

	.brand__mark-image {
		width: 100%;
		height: 100%;
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
	}

	.nav {
		justify-self: center;
	}

	.nav__list {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.nav__item {
		position: relative;
	}

	.nav__link,
	.nav__toggle {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.4rem 0;
		border: 0;
		background: transparent;
		color: var(--surface-light);
		font: inherit;
		font-size: 0.78rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-decoration: none;
		cursor: pointer;
		transition: color 220ms var(--ease-premium);
	}

	.nav__link::after,
	.nav__toggle::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -0.08rem;
		width: 100%;
		height: 2px;
		transform: scaleX(0);
		transform-origin: left center;
		background-color: var(--accent-primary);
		transition: transform 240ms var(--ease-premium);
	}

	.nav__link:hover,
	.nav__link:focus-visible,
	.nav__toggle:hover,
	.nav__toggle:focus-visible,
	.dropdown__link:hover,
	.dropdown__link:focus-visible,
	.mobile-nav__link:hover,
	.mobile-nav__link:focus-visible,
	.mobile-nav__toggle:hover,
	.mobile-nav__toggle:focus-visible,
	.mobile-subnav__link:hover,
	.mobile-subnav__link:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.nav__link:hover::after,
	.nav__link:focus-visible::after,
	.nav__toggle:hover::after,
	.nav__toggle:focus-visible::after,
	.nav__item--has-dropdown:hover > .nav__toggle::after,
	.nav__item--has-dropdown:focus-within > .nav__toggle::after {
		transform: scaleX(1);
	}

	.nav__caret {
		width: 0.45rem;
		height: 0.45rem;
		border-right: 1.5px solid currentColor;
		border-bottom: 1.5px solid currentColor;
		transform: translateY(-0.08rem) rotate(45deg);
		transition: transform 220ms var(--ease-premium);
	}

	.nav__item--has-dropdown:hover .nav__caret,
	.nav__item--has-dropdown:focus-within .nav__caret,
	.site-header[data-properties-open="true"] .mobile-nav__toggle .nav__caret {
		transform: translateY(0.04rem) rotate(225deg);
	}

	.dropdown {
		position: absolute;
		top: calc(100% + 1rem);
		left: 50%;
		min-width: 15rem;
		padding: 0.5rem;
		border: 1px solid rgba(138, 144, 152, 0.16);
		background: rgba(12, 19, 30, 0.94);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		opacity: 0;
		visibility: hidden;
		transform: translate3d(-50%, 0.5rem, 0);
		transition:
			opacity 220ms var(--ease-premium),
			transform 220ms var(--ease-premium),
			visibility 220ms var(--ease-premium);
	}

	.nav__item--has-dropdown:hover .dropdown,
	.nav__item--has-dropdown:focus-within .dropdown {
		opacity: 1;
		visibility: visible;
		transform: translate3d(-50%, 0, 0);
	}

	.dropdown__list,
	.mobile-nav,
	.mobile-subnav {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.dropdown__link {
		display: block;
		padding: 0.85rem 0.95rem;
		color: var(--surface-light);
		text-decoration: none;
		font-size: 0.92rem;
		line-height: 1.45;
		transition:
			color 220ms var(--ease-premium),
			background-color 220ms var(--ease-premium);
	}

	.dropdown__link:hover,
	.dropdown__link:focus-visible {
		background-color: rgba(199, 150, 67, 0.08);
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.header-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.9rem;
		padding: 0.72rem 1.2rem;
		background-color: var(--accent-primary);
		color: var(--bg-primary);
		border: 1px solid transparent;
		text-decoration: none;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		transition:
			transform 220ms var(--ease-premium),
			background-color 220ms var(--ease-premium);
	}

	.header-cta:hover,
	.header-cta:focus-visible {
		background-color: var(--accent-hover);
		transform: translateY(-2px);
		outline: none;
	}

	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 0.28rem;
		width: 2.9rem;
		height: 2.9rem;
		padding: 0;
		border: 1px solid rgba(138, 144, 152, 0.22);
		background: rgba(245, 243, 238, 0.02);
		color: var(--surface-light);
		cursor: pointer;
		transition:
			border-color 220ms var(--ease-premium),
			background-color 220ms var(--ease-premium);
	}

	.menu-toggle:hover,
	.menu-toggle:focus-visible {
		border-color: rgba(199, 150, 67, 0.42);
		background: rgba(199, 150, 67, 0.08);
		outline: none;
	}

	.menu-toggle span:not(.sr-only) {
		display: block;
		width: 1.1rem;
		height: 1px;
		background-color: currentColor;
		transition:
			transform 220ms var(--ease-premium),
			opacity 220ms var(--ease-premium);
	}

	.site-header[data-menu-open="true"] .menu-toggle span:nth-child(2) {
		transform: translateY(0.38rem) rotate(45deg);
	}

	.site-header[data-menu-open="true"] .menu-toggle span:nth-child(3) {
		opacity: 0;
	}

	.site-header[data-menu-open="true"] .menu-toggle span:nth-child(4) {
		transform: translateY(-0.38rem) rotate(-45deg);
	}

	.mobile-menu {
		display: none;
		border-top: 1px solid rgba(138, 144, 152, 0.14);
		background: rgba(12, 19, 30, 0.94);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		opacity: 0;
		max-height: 0;
		overflow: hidden;
		transition:
			opacity 240ms var(--ease-premium),
			max-height 240ms var(--ease-premium);
	}

	.mobile-nav__link,
	.mobile-nav__toggle,
	.mobile-subnav__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 1rem 0;
		border: 0;
		background: transparent;
		color: var(--surface-light);
		font: inherit;
		font-size: 0.94rem;
		text-decoration: none;
		cursor: pointer;
	}

	.mobile-nav__item,
	.mobile-nav > li {
		border-bottom: 1px solid rgba(138, 144, 152, 0.12);
	}

	.mobile-subnav {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 220ms var(--ease-premium);
	}

	.mobile-subnav > li {
		overflow: hidden;
	}

	.site-header[data-properties-open="true"] .mobile-subnav {
		grid-template-rows: 1fr;
	}

	.mobile-subnav__link {
		padding: 0.8rem 0 0.8rem 1rem;
		color: var(--text-secondary);
	}

	.header-cta--mobile {
		display: none;
		width: 100%;
		margin: 1rem 0 1.25rem;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 959px) {
		.site-header {
			--header-height: 4.8rem;
		}

		.site-header__inner {
			grid-template-columns: auto auto;
			justify-content: space-between;
		}

		.nav--desktop,
		.site-header__actions .header-cta {
			display: none;
		}

		.menu-toggle,
		.mobile-menu,
		.header-cta--mobile {
			display: inline-flex;
		}

		.mobile-menu {
			display: block;
		}

		.site-header[data-menu-open="true"] .mobile-menu {
			opacity: 1;
			max-height: 32rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header,
		.nav__link,
		.nav__toggle,
		.dropdown,
		.header-cta,
		.menu-toggle,
		.mobile-menu,
		.mobile-subnav {
			transition: none;
		}
	}
</style>

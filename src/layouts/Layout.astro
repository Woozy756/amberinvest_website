---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../i18n/translations";
import { loadSiteSettings } from "../sanity/siteSettings";

interface Props {
	title?: string;
	overlayHeader?: boolean;
	locale?: Locale;
}

const { locale = "lv", title, overlayHeader = false } = Astro.props;
const siteSettings = await loadSiteSettings();

if (!siteSettings) {
	throw new Error("Site Settings content is missing in Sanity.");
}

const defaultSeo = siteSettings?.defaultSeo;
const siteTitle = siteSettings.siteTitle ?? "";
const sourceTitle = title ?? defaultSeo?.metaTitle ?? siteTitle;
const pageTitle = sourceTitle.replace(/Amberinvest/gi, siteTitle);
const metaDescription = defaultSeo?.metaDescription;
const ogImage = defaultSeo?.ogImage;
const shouldNoIndex = defaultSeo?.noIndex === true;
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<script is:inline>
			if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				document.documentElement.classList.add('js-motion');
			}
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="shortcut icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		{metaDescription ? <meta name="description" content={metaDescription} /> : null}
		{shouldNoIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
		<meta property="og:title" content={pageTitle} />
		{metaDescription ? <meta property="og:description" content={metaDescription} /> : null}
		{ogImage?.url ? <meta property="og:image" content={ogImage.url} /> : null}
		{ogImage?.alt ? <meta property="og:image:alt" content={ogImage.alt} /> : null}
	</head>
	<body>
		<Header overlay={overlayHeader} locale={locale} siteSettings={siteSettings} />
		<slot />
		<Footer siteSettings={siteSettings} />
		<script is:inline>
			const revealElements = Array.from(document.querySelectorAll('.fade-in'));

			revealElements.forEach((element) => {
				const delay = element.getAttribute('data-reveal-delay');
				if (delay) {
					element.style.setProperty('--fade-in-delay', `${delay}ms`);
				}
			});

			if (!revealElements.length || !document.documentElement.classList.contains('js-motion')) {
				revealElements.forEach((element) => element.classList.add('is-visible'));
			} else if (!('IntersectionObserver' in window)) {
				revealElements.forEach((element) => element.classList.add('is-visible'));
			} else {
				const revealObserver = new IntersectionObserver(
					(entries, observer) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						});
					},
					{
						rootMargin: '0px 0px -10% 0px',
						threshold: 0.12
					}
				);

				revealElements.forEach((element) => revealObserver.observe(element));
			}
		</script>
	</body>
</html>

<style>
	html,
	body {
		width: 100%;
		min-height: 100%;
	}
</style>

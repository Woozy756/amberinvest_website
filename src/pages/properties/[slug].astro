---
import Layout from "../../layouts/Layout.astro";
import PropertyCard from "../../components/properties/PropertyCard.astro";
import PropertyGallery from "../../components/properties/PropertyGallery.jsx";
import PropertyInquirySection from "../../components/properties/PropertyInquirySection.astro";
import FloorPlansSection, { type FloorPlanTab } from "../../components/shared/FloorPlansSection.astro";
import plan2Room from "../../assets/plans/plan2room.png";
import plan3Room from "../../assets/plans/plan3room.png";
import {
	getAllProperties,
	getCategoryBySlug,
	getPropertyBySlug,
	getSimilarProperties,
	propertyStatusMeta,
	type Property
} from "../../data/properties";

export function getStaticPaths() {
	return getAllProperties().map((property) => ({
		params: { slug: property.slug },
		props: { property }
	}));
}

interface PropertyPageProps {
	property: Property;
}

const locale = "lv";
const { property: propertyFromProps } = Astro.props as PropertyPageProps;
const property = getPropertyBySlug(Astro.params.slug ?? "") ?? propertyFromProps;
const category = getCategoryBySlug(property.category);
const priceFormatter = new Intl.NumberFormat("lv-LV");
const status = propertyStatusMeta[property.status];
const similarProperties = getSimilarProperties(property.slug, 3);
const gallery =
	property.gallery?.length > 0
		? property.gallery
		: property.image
			? [{ src: property.image, alt: property.title }]
			: [];
const details =
	property.details?.length > 0
		? property.details
		: [
				{ label: "Istabu skaits", value: String(property.rooms) },
				{ label: "Kopējā platība", value: `${property.area.toFixed(1)} m²` },
				{ label: "Stāvs", value: `${property.floor}. stāvs` },
				{ label: "Statuss", value: status.label }
			];

const keyFacts = [
	{ label: "Istabas", value: String(property.rooms) },
	{ label: "Platība", value: `${property.area.toFixed(1)} m²` },
	{ label: "Stāvs", value: `${property.floor}. stāvs` },
	{ label: "Statuss", value: status.label }
];

const planImageByCategory = {
	divistabu: plan2Room.src,
	trisistabu: plan3Room.src,
	cetristabu: "/property-floor-plan.svg"
} as const;

const planBreakdownByCategory: Record<
	Property["category"],
	{ livingKitchen: string; bedroom: string; bathroom: string; hallway: string }
> = {
	divistabu: {
		livingKitchen: "23.8 m²",
		bedroom: "12.4 m²",
		bathroom: "4.6 m²",
		hallway: "7.9 m²"
	},
	trisistabu: {
		livingKitchen: "27.6 m²",
		bedroom: "13.4 m²",
		bathroom: "5.2 m²",
		hallway: "9.3 m²"
	},
	cetristabu: {
		livingKitchen: "34.8 m²",
		bedroom: "16.2 m²",
		bathroom: "6.1 m²",
		hallway: "11.7 m²"
	}
};

const planBreakdown = planBreakdownByCategory[property.category];
const floorPlans: FloorPlanTab[] = [
	{
		id: property.category,
		tabLabel: `${property.rooms} istabas`,
		title: `${property.rooms} istabu plāns`,
		price: `€${priceFormatter.format(property.price)}`,
		image: planImageByCategory[property.category],
		imageAlt: `${property.rooms} istabu dzīvokļa plāns`,
		ctaText: "Pieteikt apskati",
		ctaLink: "#property-inquiry",
		specs: [
			{ label: "Kopējā platība", value: `${property.area.toFixed(1)} m²` },
			{ label: "Dzīvojamā istaba + virtuve", value: planBreakdown.livingKitchen },
			{ label: "Guļamistaba", value: planBreakdown.bedroom },
			{ label: "Vannas istaba", value: planBreakdown.bathroom },
			{ label: "Priekštelpa", value: planBreakdown.hallway },
			{ label: "Apdare", value: "Pilna apdare" }
		]
	}
];
---

<Layout title={`Amberinvest | ${property.title}`} locale={locale}>
	<main class="property-page">
		<section class="property-hero">
			<div class="property-page__container">
				<nav class="property-breadcrumbs fade-in" aria-label="Ceļa karte">
					<a href="/">Sākums</a>
					<span aria-hidden="true">/</span>
					<a href="/properties">Dzīvokļi</a>
					<span aria-hidden="true">/</span>
					<a href={`/properties/type/${property.category}`}>{category?.label}</a>
					<span aria-hidden="true">/</span>
					<span aria-current="page">{property.title}</span>
				</nav>

				<div class="property-hero__grid">
					<div class="property-hero__gallery fade-in" data-reveal-delay="70">
						<PropertyGallery client:idle images={gallery} title={property.title} />
					</div>

					<div class="property-hero__summary fade-in" data-reveal-delay="130">
						<p class="property-page__eyebrow">{category?.label ?? "Dzīvoklis"}</p>
						<h1 class="property-hero__title">{property.title}</h1>

						<div class="property-hero__headline-row">
							<p class="property-hero__price">€{priceFormatter.format(property.price)}</p>
							<p class="property-status-badge" data-tone={status.tone}>{status.label}</p>
						</div>

						<p class="property-hero__lead">{property.shortDescription}</p>

						<dl class="property-hero__facts" aria-label={`${property.title} pamatinformācija`}>
							{
								keyFacts.map((fact) => (
									<div>
										<dt>{fact.label}</dt>
										<dd>{fact.value}</dd>
									</div>
								))
							}
						</dl>

						<div class="property-hero__actions">
							<a class="property-hero__cta" href="#property-inquiry">Pieteikt apskati</a>
							<p class="property-hero__cta-note">
								Atbildam 24 stundu laikā un sagatavojam arī līdzīgo plānojumu piedāvājumus.
							</p>
						</div>

						<div class="property-hero__contact-row" aria-label="Kontakti">
							<a href="tel:+37120001234">+371 20 001 234</a>
							<a href="mailto:info@amberinvest.lv">info@amberinvest.lv</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="property-section">
			<div class="property-page__container">
				<div class="property-story fade-in">
					<div class="property-section__heading">
						<p class="property-page__eyebrow">Par dzīvokli</p>
						<h2>Dzīves telpa ar skaidru plānojuma loģiku</h2>
					</div>

					<div class="property-story__content">
						<p>{property.description}</p>
					</div>
				</div>
			</div>
		</section>

		<FloorPlansSection
			eyebrow="Plānojumi"
			title={`${property.rooms} istabu dzīvokļa plāns`}
			lead="Plānojuma pārskats ar svarīgākajām telpu zonām un apdares informāciju."
			tabsAriaLabel="Dzīvokļu plānojumu izvēle"
			specsAriaLabel="Plānojuma specifikācija"
			plans={floorPlans}
			initialTabId={property.category}
			showTabs={false}
		/>

		<section class="property-section">
			<div class="property-page__container">
				<div class="property-details fade-in">
					<header class="property-section__heading property-section__heading--compact">
						<p class="property-page__eyebrow">Specifikācija</p>
						<h2>Detalizēta informācija</h2>
					</header>

					<dl class="property-details__grid">
						{
							details.map((detail) => (
								<div>
									<dt>{detail.label}</dt>
									<dd>{detail.value}</dd>
								</div>
							))
						}
					</dl>
				</div>
			</div>
		</section>

		<PropertyInquirySection property={property} />

		{
			similarProperties.length ? (
				<section class="property-section property-section--similar">
					<div class="property-page__container">
						<div class="property-section__heading property-section__heading--wide fade-in">
							<div>
								<p class="property-page__eyebrow">Līdzīgi dzīvokļi</p>
								<h2>Vēl daži pārdomāti piedāvājumi šajā kolekcijā</h2>
							</div>
							<p>
								Salīdziniet plānojumus, cenu līmeni un pieejamību, lai ātrāk pieņemtu lēmumu par
								atbilstošāko dzīvokli.
							</p>
						</div>

						<ul class="property-related__grid" role="list">
							{
								similarProperties.map((relatedProperty, index) => (
									<li>
										<PropertyCard property={relatedProperty} index={index} />
									</li>
								))
							}
						</ul>
					</div>
				</section>
			) : null
		}
	</main>
</Layout>

<style is:global>
	.property-page {
		padding-top: clamp(7rem, 9vw, 9rem);
		background:
			radial-gradient(circle at top left, rgba(199, 150, 67, 0.08), transparent 26%),
			linear-gradient(180deg, #f7f4ed 0%, var(--surface-light) 34%, #f1ece2 100%);
		color: var(--bg-primary);
	}

	.property-page__container {
		width: min(100%, 1280px);
		margin: 0 auto;
		padding-inline: clamp(1.5rem, 4vw, 3rem);
	}

	.property-page__eyebrow {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-primary);
	}

	.property-breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: clamp(1.5rem, 2.6vw, 2rem);
		font-size: 0.69rem;
		font-weight: 700;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.property-breadcrumbs a,
	.property-breadcrumbs span {
		color: rgba(15, 17, 21, 0.46);
		text-decoration: none;
	}

	.property-breadcrumbs a:hover,
	.property-breadcrumbs a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.property-hero {
		padding-bottom: clamp(4rem, 6vw, 5rem);
	}

	.property-hero__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.22fr) minmax(19rem, 0.78fr);
		gap: clamp(2rem, 4vw, 4rem);
		align-items: start;
	}

	.property-hero__summary {
		position: sticky;
		top: 6.75rem;
		display: grid;
		gap: 1.35rem;
		padding-left: clamp(1rem, 2vw, 1.6rem);
		border-left: 1px solid rgba(35, 38, 43, 0.12);
	}

	.property-hero__title,
	.property-section__heading h2 {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		letter-spacing: -0.025em;
	}

	.property-hero__title {
		font-size: clamp(2.2rem, 4vw, 4.1rem);
		line-height: 1.02;
		max-width: 12ch;
		text-wrap: balance;
	}

	.property-hero__headline-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem 1rem;
		padding-bottom: 1.2rem;
		border-bottom: 1px solid rgba(35, 38, 43, 0.1);
	}

	.property-hero__price {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(2rem, 3.2vw, 3rem);
		line-height: 1;
		letter-spacing: -0.03em;
	}

	.property-status-badge {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		padding: 0.35rem 0.72rem;
		border: 1px solid transparent;
		background: rgba(255, 255, 255, 0.76);
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.property-status-badge[data-tone="available"] {
		border-color: rgba(80, 129, 96, 0.18);
		color: #3f6d4b;
	}

	.property-status-badge[data-tone="reserved"] {
		border-color: rgba(199, 150, 67, 0.24);
		color: #966f29;
	}

	.property-status-badge[data-tone="sold"] {
		border-color: rgba(118, 124, 134, 0.18);
		color: #5c6169;
	}

	.property-hero__lead {
		margin: 0;
		max-width: 42ch;
		font-size: 1rem;
		line-height: 1.78;
		color: rgba(15, 17, 21, 0.66);
	}

	.property-hero__facts {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
		margin: 0;
	}

	.property-hero__facts div {
		padding: 0.95rem 0.95rem 1rem;
		border: 1px solid rgba(35, 38, 43, 0.1);
		background: rgba(255, 255, 255, 0.7);
	}

	.property-hero__facts dt,
	.property-details__grid dt {
		margin: 0;
		font-size: 0.63rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(15, 17, 21, 0.46);
	}

	.property-hero__facts dd,
	.property-details__grid dd {
		margin: 0.45rem 0 0;
		font-size: 1.04rem;
		line-height: 1.5;
		color: var(--bg-primary);
	}

	.property-hero__actions {
		display: grid;
		gap: 0.8rem;
		padding-top: 0.2rem;
	}

	.property-hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		min-height: 3rem;
		padding: 0.65rem 1.15rem;
		background: var(--accent-primary);
		color: var(--bg-primary);
		text-decoration: none;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		transition:
			background-color 180ms var(--ease-premium),
			transform 180ms var(--ease-premium);
	}

	.property-hero__cta:hover,
	.property-hero__cta:focus-visible {
		background: var(--accent-hover);
		transform: translateY(-2px);
		outline: none;
	}

	.property-hero__cta-note {
		margin: 0;
		max-width: 34ch;
		font-size: 0.9rem;
		line-height: 1.65;
		color: rgba(15, 17, 21, 0.56);
	}

	.property-hero__contact-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem 1.2rem;
		padding-top: 1.2rem;
		border-top: 1px solid rgba(35, 38, 43, 0.1);
	}

	.property-hero__contact-row a {
		color: var(--bg-primary);
		text-decoration: none;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.property-hero__contact-row a:hover,
	.property-hero__contact-row a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.property-gallery {
		display: grid;
		gap: 1rem;
	}

	.property-gallery__stage {
		position: relative;
		overflow: clip;
		aspect-ratio: 1.07;
		background: rgba(15, 17, 21, 0.06);
	}

	.property-gallery__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.property-gallery__meta {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.55rem 0.75rem;
		background: rgba(15, 17, 21, 0.7);
		color: var(--surface-light);
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		backdrop-filter: blur(8px);
	}

	.property-gallery__meta strong {
		color: var(--accent-primary);
	}

	.property-gallery__thumbs {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.property-gallery__thumb {
		padding: 0;
		border: 1px solid rgba(35, 38, 43, 0.12);
		background: rgba(255, 255, 255, 0.72);
		overflow: clip;
		cursor: pointer;
		transition:
			transform 0.35s var(--ease-premium),
			border-color 0.35s var(--ease-premium),
			opacity 0.35s var(--ease-premium);
	}

	.property-gallery__thumb[aria-pressed="true"] {
		border-color: rgba(199, 150, 67, 0.65);
	}

	.property-gallery__thumb:hover,
	.property-gallery__thumb:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(199, 150, 67, 0.42);
		outline: none;
	}

	.property-gallery__thumb img {
		width: 100%;
		height: 100%;
		aspect-ratio: 1.22;
		object-fit: cover;
		opacity: 0.82;
		transition: opacity 0.3s var(--ease-premium);
	}

	.property-gallery__thumb[aria-pressed="true"] img,
	.property-gallery__thumb:hover img,
	.property-gallery__thumb:focus-visible img {
		opacity: 1;
	}

	.property-section {
		padding: clamp(4rem, 7vw, 5.6rem) 0;
		border-top: 1px solid rgba(35, 38, 43, 0.08);
	}

	.property-story {
		display: grid;
		grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
		gap: clamp(1.8rem, 4vw, 3.2rem);
		align-items: start;
	}

	.property-section__heading {
		display: grid;
		gap: 0.85rem;
	}

	.property-section__heading--compact {
		margin-bottom: 1.7rem;
	}

	.property-section__heading--wide {
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.7fr);
		align-items: end;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.property-section__heading h2 {
		font-size: clamp(1.9rem, 3vw, 3rem);
		line-height: 1.06;
		max-width: 13ch;
	}

	.property-section__heading--wide h2 {
		max-width: 15ch;
	}

	.property-section__heading--wide p:last-child {
		margin: 0;
		max-width: 38ch;
		font-size: 0.98rem;
		line-height: 1.72;
		color: rgba(15, 17, 21, 0.62);
	}

	.property-story__content {
		max-width: 52rem;
	}

	.property-story__content p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.82;
		color: rgba(15, 17, 21, 0.68);
	}

	.property-details {
		padding: clamp(1.5rem, 3vw, 2rem);
		border: 1px solid rgba(35, 38, 43, 0.1);
		background: rgba(255, 255, 255, 0.76);
	}

	.property-details__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
	}

	.property-details__grid div {
		padding: 1rem 0.95rem 1.05rem;
		border: 1px solid rgba(35, 38, 43, 0.08);
		background: rgba(245, 243, 238, 0.72);
	}

	.property-section--similar {
		padding-bottom: clamp(5rem, 8vw, 7rem);
	}

	.property-related__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1.2rem, 2vw, 1.7rem);
	}

	.property-related__grid li {
		min-width: 0;
	}

	@media (max-width: 1080px) {
		.property-hero__grid,
		.property-story,
		.property-section__heading--wide {
			grid-template-columns: 1fr;
		}

		.property-hero__summary {
			position: static;
			padding-left: 0;
			border-left: 0;
			padding-top: 0.5rem;
			border-top: 1px solid rgba(35, 38, 43, 0.1);
		}

		.property-details__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.property-related__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.property-hero {
			padding-bottom: 3rem;
		}

		.property-gallery__thumbs {
			grid-template-columns: repeat(4, minmax(4.2rem, 1fr));
			overflow-x: auto;
			padding-bottom: 0.1rem;
		}

		.property-hero__facts,
		.property-details__grid,
		.property-related__grid {
			grid-template-columns: 1fr;
		}

		.property-hero__cta {
			width: 100%;
		}

		.property-details {
			padding-inline: 1rem;
		}
	}
</style>

---
import Layout from "../../../layouts/Layout.astro";
import PropertyCard from "../../../components/properties/PropertyCard.astro";
import PropertyGallery from "../../../components/properties/PropertyGallery.jsx";
import PropertyInquirySection from "../../../components/properties/PropertyInquirySection.astro";
import PropertyLocationMap from "../../../components/properties/PropertyLocationMap.astro";
import FloorPlansSection from "../../../components/shared/FloorPlansSection.astro";
import {
	getAllProperties,
	getPropertyCategoryHref,
	getSimilarProperties,
	type Property
} from "../../../sanity/properties";
import { createPropertyPageViewModel } from "../../../lib/propertyPage";

export async function getStaticPaths() {
	const properties = await getAllProperties();

	return properties.map((property) => ({
		params: {
			category: property.category.slug,
			slug: property.slug
		},
		props: { property }
	}));
}

const locale = "lv";
const { property } = Astro.props as { property: Property };

const { status, priceLabel, descriptionParagraphs, locationLabel, aboutSectionTitle, keyFacts, floorPlans } =
	createPropertyPageViewModel(property);
const similarProperties = await getSimilarProperties(property.slug, property.category.slug, 3);
const gallery = property.gallery;
---

<Layout title={`Amberinvest | ${property.title}`} locale={locale}>
	<main class="property-page">
		<section class="property-hero">
			<div class="property-page__container">
				<nav class="property-breadcrumbs fade-in text-xs font-bold tracking-[0.13em] uppercase" aria-label="Ceļa karte">
					<a href="/">Sākums</a>
					<span aria-hidden="true">/</span>
					<a href="/properties">Dzīvokļi</a>
					<span aria-hidden="true">/</span>
					<a href={getPropertyCategoryHref(property.category)}>{property.category.label}</a>
					<span aria-hidden="true">/</span>
					<span aria-current="page">{property.title}</span>
				</nav>

				<div class="property-hero__grid">
					<div class="property-hero__gallery fade-in" data-reveal-delay="70">
						<PropertyGallery client:idle images={gallery} title={property.title} />
					</div>

					<div class="property-hero__summary fade-in" data-reveal-delay="130">
						<p class="property-page__eyebrow property-hero__location text-xs font-bold tracking-[0.16em] uppercase">
							<svg
								class="property-hero__location-icon"
								viewBox="0 0 24 24"
								aria-hidden="true"
								focusable="false"
							>
								<path
									d="M12 2.5c-3.86 0-7 3.14-7 7 0 4.8 5.69 11.1 6.33 11.8a.9.9 0 0 0 1.34 0C13.31 20.6 19 14.3 19 9.5c0-3.86-3.14-7-7-7Zm0 9.5a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
									fill="currentColor"
								/>
							</svg>
							<span>{locationLabel}</span>
						</p>
						<h1 class="property-hero__title font-['Playfair_Display',Georgia,serif] text-4xl md:text-5xl lg:text-6xl xl:text-7xl leading-[1.02] tracking-[-0.025em]">
							{property.title}
						</h1>

						<div class="property-hero__headline-row">
							<p class="property-hero__price font-['Playfair_Display',Georgia,serif] text-4xl md:text-5xl leading-[1] tracking-[-0.03em]">
								{priceLabel}
							</p>
							<p class="property-status-badge text-xs font-bold tracking-[0.14em] uppercase" data-tone={status.tone}>
								{status.label}
							</p>
						</div>

						<p class="property-hero__lead text-base leading-[1.78]">{property.shortDescription}</p>

						<dl class="property-hero__facts" aria-label={`${property.title} pamatinformācija`}>
							{
								keyFacts.map((fact) => (
									<div>
										<dt class="text-xs font-bold tracking-[0.14em] uppercase">{fact.label}</dt>
										<dd class="text-base leading-[1.5]">{fact.value}</dd>
									</div>
								))
							}
						</dl>

						<div class="property-hero__actions">
							<a class="property-hero__cta text-xs font-bold tracking-[0.15em] uppercase" href="#property-inquiry">
								Pieteikt apskati
							</a>
							<p class="property-hero__cta-note text-sm leading-[1.65]">
								Atbildam 24 stundu laikā un sagatavojam arī līdzīgo plānojumu piedāvājumus.
							</p>
						</div>

						<div class="property-hero__contact-row" aria-label="Kontakti">
							<a class="text-xs font-bold tracking-[0.14em] uppercase" href="tel:+37120001234">+371 20 001 234</a>
							<a class="text-xs font-bold tracking-[0.14em] uppercase" href="mailto:info@amberinvest.lv">
								info@amberinvest.lv
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<FloorPlansSection
			eyebrow=""
			title={property.floorPlanSectionTitle || `${property.rooms} istabu dzīvokļa plāns`}
			lead={property.floorPlanNote || "Plānojuma pārskats ar svarīgākajām telpu zonām un apdares informāciju."}
			tabsAriaLabel="Dzīvokļu plānojumu izvēle"
			specsAriaLabel="Plānojuma specifikācija"
			plans={floorPlans}
			initialTabId={property.category.slug}
			showTabs={false}
		/>

		<section class="property-section">
			<div class="property-page__container">
				<div class="property-about fade-in">
					<div class="property-about__content">
						<div class="property-section__heading property-section__heading--about">
							<p class="property-page__eyebrow text-xs font-bold tracking-[0.16em] uppercase">Par dzīvokli</p>
							<h2 class="font-['Playfair_Display',Georgia,serif] text-3xl md:text-4xl lg:text-5xl leading-[1.12] tracking-[-0.025em]">
								{aboutSectionTitle}
							</h2>
						</div>

						<div class="property-about__description">
							{
								descriptionParagraphs.map((paragraph) => (
									<p class="text-lg leading-[1.92]">{paragraph}</p>
								))
							}
						</div>
					</div>

					<div class="property-about__map">
						<PropertyLocationMap project={property.project} />
					</div>
				</div>
			</div>
		</section>

		<PropertyInquirySection property={property} />

		{
			similarProperties.length ? (
				<section class="property-section property-section--similar">
					<div class="property-page__container">
						<div class="property-section__heading property-section__heading--wide fade-in">
							<div>
								<p class="property-page__eyebrow text-xs font-bold tracking-[0.16em] uppercase">Līdzīgi dzīvokļi</p>
								<h2 class="font-['Playfair_Display',Georgia,serif] text-3xl md:text-4xl lg:text-5xl leading-[1.06] tracking-[-0.025em]">
									Vēl daži pārdomāti piedāvājumi šajā kolekcijā
								</h2>
							</div>
							<p class="text-base leading-[1.72]">
								Salīdziniet plānojumus, cenu līmeni un pieejamību, lai ātrāk pieņemtu lēmumu par
								atbilstošāko dzīvokli.
							</p>
						</div>

						<ul class="property-related__grid" role="list">
							{
								similarProperties.map((relatedProperty, index) => (
									<li>
										<PropertyCard property={relatedProperty} index={index} />
									</li>
								))
							}
						</ul>
					</div>
				</section>
			) : null
		}
	</main>
</Layout>

<style is:global>
	.property-page {
		padding-top: clamp(7rem, 9vw, 9rem);
		background:
			radial-gradient(circle at top left, rgba(199, 150, 67, 0.08), transparent 26%),
			linear-gradient(180deg, #f7f4ed 0%, var(--surface-light) 34%, #f1ece2 100%);
		color: var(--bg-primary);
	}

	.property-page__container {
		width: min(100%, 1280px);
		margin: 0 auto;
		padding-inline: clamp(1.5rem, 4vw, 3rem);
	}

	.property-page__eyebrow {
		margin: 0;
		color: var(--accent-primary);
	}

	.property-hero__location {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
	}

	.property-hero__location-icon {
		width: 1rem;
		height: 1rem;
		min-width: 1rem;
		min-height: 1rem;
		max-width: 1rem;
		max-height: 1rem;
		color: var(--accent-primary);
		flex: 0 0 auto;
		display: block;
	}

	.property-breadcrumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: clamp(1.5rem, 2.6vw, 2rem);
	}

	.property-breadcrumbs a,
	.property-breadcrumbs span {
		color: rgba(15, 17, 21, 0.46);
		text-decoration: none;
	}

	.property-breadcrumbs a:hover,
	.property-breadcrumbs a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.property-hero {
		padding-bottom: clamp(4rem, 6vw, 5rem);
	}

	.property-hero__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.22fr) minmax(19rem, 0.78fr);
		gap: clamp(2rem, 4vw, 4rem);
		align-items: start;
	}

	.property-hero__summary {
		position: sticky;
		top: 6.75rem;
		display: grid;
		gap: 1.35rem;
		padding-left: clamp(1rem, 2vw, 1.6rem);
		border-left: 1px solid rgba(35, 38, 43, 0.12);
	}

	.property-hero__title,
	.property-section__heading h2 {
		margin: 0;
	}

	.property-hero__title {
		max-width: 12ch;
		text-wrap: balance;
	}

	.property-hero__headline-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem 1rem;
		padding-bottom: 1.2rem;
		border-bottom: 1px solid rgba(35, 38, 43, 0.1);
	}

	.property-hero__price {
		margin: 0;
	}

	.property-status-badge {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		padding: 0.35rem 0.72rem;
		border: 1px solid transparent;
		background: rgba(255, 255, 255, 0.76);
	}

	.property-status-badge[data-tone="available"] {
		border-color: rgba(80, 129, 96, 0.18);
		color: #3f6d4b;
	}

	.property-status-badge[data-tone="reserved"] {
		border-color: rgba(199, 150, 67, 0.24);
		color: #966f29;
	}

	.property-status-badge[data-tone="sold"] {
		border-color: rgba(118, 124, 134, 0.18);
		color: #5c6169;
	}

	.property-hero__lead {
		margin: 0;
		max-width: 42ch;
		color: rgba(15, 17, 21, 0.66);
	}

	.property-hero__facts {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
		margin: 0;
	}

	.property-hero__facts div {
		padding: 0.95rem 0.95rem 1rem;
		border: 1px solid rgba(35, 38, 43, 0.1);
		background: rgba(255, 255, 255, 0.7);
	}

	.property-hero__facts dt {
		margin: 0;
		color: rgba(15, 17, 21, 0.46);
	}

	.property-hero__facts dd {
		margin: 0.45rem 0 0;
		color: var(--bg-primary);
	}

	.property-hero__actions {
		display: grid;
		gap: 0.8rem;
		padding-top: 0.2rem;
	}

	.property-hero__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		min-height: 3rem;
		padding: 0.65rem 1.15rem;
		background: var(--accent-primary);
		color: var(--bg-primary);
		text-decoration: none;
		transition:
			background-color 180ms var(--ease-premium),
			transform 180ms var(--ease-premium);
	}

	.property-hero__cta:hover,
	.property-hero__cta:focus-visible {
		background: var(--accent-hover);
		transform: translateY(-2px);
		outline: none;
	}

	.property-hero__cta-note {
		margin: 0;
		max-width: 34ch;
		color: rgba(15, 17, 21, 0.56);
	}

	.property-hero__contact-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem 1.2rem;
		padding-top: 1.2rem;
		border-top: 1px solid rgba(35, 38, 43, 0.1);
	}

	.property-hero__contact-row a {
		color: var(--bg-primary);
		text-decoration: none;
	}

	.property-hero__contact-row a:hover,
	.property-hero__contact-row a:focus-visible {
		color: var(--accent-primary);
		outline: none;
	}

	.property-gallery {
		display: grid;
		gap: 1rem;
	}

	.property-gallery__stage {
		position: relative;
		overflow: clip;
		aspect-ratio: 1.07;
		background: rgba(15, 17, 21, 0.06);
	}

	.property-gallery__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.property-gallery__meta {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.55rem 0.75rem;
		background: rgba(15, 17, 21, 0.7);
		color: var(--surface-light);
		backdrop-filter: blur(8px);
	}

	.property-gallery__meta strong {
		color: var(--accent-primary);
	}

	.property-gallery__thumbs {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.property-gallery__thumb {
		padding: 0;
		border: 1px solid rgba(35, 38, 43, 0.12);
		background: rgba(255, 255, 255, 0.72);
		overflow: clip;
		cursor: pointer;
		transition:
			transform 0.35s var(--ease-premium),
			border-color 0.35s var(--ease-premium),
			opacity 0.35s var(--ease-premium);
	}

	.property-gallery__thumb[aria-pressed="true"] {
		border-color: rgba(199, 150, 67, 0.65);
	}

	.property-gallery__thumb:hover,
	.property-gallery__thumb:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(199, 150, 67, 0.42);
		outline: none;
	}

	.property-gallery__thumb img {
		width: 100%;
		height: 100%;
		aspect-ratio: 1.22;
		object-fit: cover;
		opacity: 0.82;
		transition: opacity 0.3s var(--ease-premium);
	}

	.property-gallery__thumb[aria-pressed="true"] img,
	.property-gallery__thumb:hover img,
	.property-gallery__thumb:focus-visible img {
		opacity: 1;
	}

	.property-section {
		padding: clamp(4rem, 7vw, 5.6rem) 0;
		border-top: 1px solid rgba(35, 38, 43, 0.08);
	}

	.property-about {
		display: grid;
		grid-template-columns: minmax(0, 0.72fr) minmax(32rem, 1.28fr);
		gap: clamp(1.8rem, 3.3vw, 2.7rem);
		align-items: start;
	}

	.property-about__content {
		display: grid;
		gap: clamp(1.1rem, 2vw, 1.6rem);
		align-content: start;
	}

	.property-section__heading {
		display: grid;
		gap: 0.85rem;
	}

	.property-section__heading--wide {
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.7fr);
		align-items: end;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.property-section__heading h2 {
		max-width: 13ch;
	}

	.property-section__heading--about h2 {
		max-width: 22ch;
	}

	.property-section__heading--wide h2 {
		max-width: 15ch;
	}

	.property-section__heading--wide p:last-child {
		margin: 0;
		max-width: 38ch;
		color: rgba(15, 17, 21, 0.62);
	}

	.property-about__description {
		width: 100%;
	}

	.property-about__description p {
		margin: 0;
		color: rgba(15, 17, 21, 0.68);
	}

	.property-about__description p + p {
		margin-top: 1.35rem;
	}

	.property-about__map {
		position: sticky;
		top: 6.75rem;
	}

	.property-location-map {
		display: grid;
		gap: 0.85rem;
	}

	.property-location-map__frame {
		overflow: clip;
		height: clamp(24rem, 38vw, 30rem);
	}

	.property-location-map__frame iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
	}

	.property-location-map__meta {
		display: block;
		padding: 0.35rem 0 0;
		border-top: 0;
		border-bottom: 0;
		background: transparent;
	}

	.property-location-map__subtitle {
		margin: 0;
		color: rgba(15, 17, 21, 0.66);
	}

	.property-location-map__actions {
		display: flex;
		justify-content: space-between;
		align-items: center;
		min-height: 1.6rem;
		gap: 1rem;
		line-height: 1.3;
	}

	.property-location-map__link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		width: fit-content;
		color: var(--accent-primary);
		text-decoration: none;
	}

	.property-location-map__arrow {
		width: 0.78rem;
		height: 0.78rem;
		flex: 0 0 auto;
	}

	.property-location-map__link:hover,
	.property-location-map__link:focus-visible {
		color: var(--accent-hover);
		outline: none;
	}

	.property-location-map__empty {
		display: grid;
		place-items: center;
		min-height: 14rem;
		padding: 1rem;
		border: 1px dashed rgba(35, 38, 43, 0.2);
		background: rgba(255, 255, 255, 0.55);
	}

	.property-location-map__empty p {
		margin: 0;
		text-align: center;
		color: rgba(15, 17, 21, 0.58);
	}

	.property-section--similar {
		padding-bottom: clamp(5rem, 8vw, 7rem);
	}

	.property-related__grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1.2rem, 2vw, 1.7rem);
	}

	.property-related__grid li {
		min-width: 0;
	}

	@media (max-width: 1080px) {
		.property-hero__grid,
		.property-about,
		.property-section__heading--wide {
			grid-template-columns: 1fr;
		}

		.property-hero__summary {
			position: static;
			padding-left: 0;
			border-left: 0;
			padding-top: 0.5rem;
			border-top: 1px solid rgba(35, 38, 43, 0.1);
		}

		.property-related__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.property-about__map {
			position: static;
		}
	}

	@media (max-width: 720px) {
		.property-hero {
			padding-bottom: 3rem;
		}

		.property-gallery__thumbs {
			grid-template-columns: repeat(4, minmax(4.2rem, 1fr));
			overflow-x: auto;
			padding-bottom: 0.1rem;
		}

		.property-hero__facts,
		.property-related__grid {
			grid-template-columns: 1fr;
		}

		.property-hero__cta {
			width: 100%;
		}
	}
</style>
